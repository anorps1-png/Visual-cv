# === Fournisseurs IA ===
# Clé API compatible OpenAI (ex : Sublyx, OpenAI, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
DEEPSEEK_API_KEY=

# === Supabase ===
# Exposées au navigateur (préfixe NEXT_PUBLIC_) : URL + clé anon publique
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVEUR UNIQUEMENT — ne JAMAIS préfixer NEXT_PUBLIC_, ne jamais exposer au client.
# Utilisée pour écrire les offres d'emploi scrapées et gérer les abonnements
# (contourne RLS). À récupérer dans Supabase > Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=

# === Paiement / Abonnements ===
# URL publique de l'app (callbacks & redirections PSP). Ex : http://localhost:3000
APP_URL=http://localhost:3000

# Adaptateur de paiement : 'mock' (sandbox, confirme immédiatement — aucun compte
# marchand requis) ou 'kpay' (Mobile Money réel).
PAYMENT_PROVIDER=mock

# KPay — requis uniquement si PAYMENT_PROVIDER=kpay.
# ⚠️ Voir les `// TODO KPAY:` dans src/lib/payments/kpay.ts : les endpoints et le
# format du webhook doivent être confirmés depuis ton tableau de bord marchand.
KPAY_BASE_URL=
KPAY_API_KEY=
KPAY_WEBHOOK_SECRET=

# === Cron (alimentation des offres d'emploi) ===
# Protège /api/cron/scrape-jobs : sans ce secret, n'importe qui pourrait
# déclencher des scrapings en boucle. Vercel Cron l'envoie automatiquement
# en en-tête `Authorization: Bearer $CRON_SECRET`.
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
